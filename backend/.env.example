# Copy to .env and adjust. Committed as .env.example only (.env is gitignored).

NODE_ENV=development
PORT=3000

# Required for Prisma (local Postgres or hosted, e.g. Neon).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tranzo

# Optional overrides (development has defaults for everything below)
# JWT_SECRET=your-secret
# REDIS_URL=redis://127.0.0.1:6379

# Match Android BuildConfig.ACCOUNT_FACTORY_ADDRESS / your deployed factory on Amoy
# FACTORY_ADDRESS=0x1b41BbeDAAeDAf82E9D4Bc25dB3DB6144eEbC4E6

# RPC for Polygon Amoy (app DEFAULT_CHAIN_ID=80002)
# POLYGON_AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# Production also needs POLYGON_RPC_URL, PIMLICO_API_KEY, real paymaster + Immersve vars — see src/config/env.ts
