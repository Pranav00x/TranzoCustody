generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String         @id @default(cuid())
  smartWalletAddr String         @unique
  ownerAddr       String         @unique
  chainId         Int
  kycStatus       KycStatus      @default(NONE)
  kycProvider     String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  cards           Card[]
  cardSessions    CardSession[]
  sentStreams     Stream[]        @relation("sender")
  refreshTokens  RefreshToken[]
  gasUsageToday   Float          @default(0)
  lastGasReset    DateTime       @default(now())
}

/// Stores SIWE nonces — short-lived, deleted after use or expiry.
model Nonce {
  id        String   @id @default(cuid())
  value     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}

/// Rotating refresh tokens — one active per device/session.
model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  family    String
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([family])
  @@index([expiresAt])
}

model Card {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  provider        CardProvider
  externalId      String        @unique
  type            CardType
  status          CardStatus    @default(ACTIVE)
  last4           String?
  dailyLimit      BigInt        @default(50000000)
  createdAt       DateTime      @default(now())
}

model CardSession {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  sessionKeyAddr  String
  provider        CardProvider
  dailyLimit      BigInt
  perTxLimit      BigInt
  validUntil      DateTime
  active          Boolean       @default(true)
  txHash          String?
  createdAt       DateTime      @default(now())
}

model Stream {
  id                String        @id @default(cuid())
  onChainStreamId   Int?
  senderId          String
  sender            User          @relation("sender", fields: [senderId], references: [id])
  recipientAddr     String
  token             String
  totalAmount       BigInt
  withdrawn         BigInt        @default(0)
  startTime         DateTime
  endTime           DateTime
  status            StreamStatus  @default(ACTIVE)
  txHash            String?
  createdAt         DateTime      @default(now())
}

model WebhookEvent {
  id              String        @id @default(cuid())
  provider        String
  eventType       String
  payload         Json
  processed       Boolean       @default(false)
  createdAt       DateTime      @default(now())
}

enum KycStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

enum CardProvider {
  IMMERSVE
  REAP
}

enum CardType {
  VIRTUAL
  PHYSICAL
}

enum CardStatus {
  ACTIVE
  FROZEN
  CANCELLED
  EXPIRED
}

enum StreamStatus {
  ACTIVE
  PAUSED
  CANCELLED
  COMPLETED
}
