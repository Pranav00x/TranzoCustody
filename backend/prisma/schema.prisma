generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String         @id @default(cuid())
  email           String         @unique
  passwordHash    String
  emailVerified   Boolean        @default(false)
  smartWalletAddr String         @unique
  ownerAddr       String         @unique
  chainId         Int
  kycStatus       KycStatus      @default(NONE)
  kycProvider     String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  transactions    Transaction[]
  cards           Card[]
  cardSessions    CardSession[]
  sentStreams     Stream[]        @relation("sender")
  refreshTokens  RefreshToken[]
  resetTokens    PasswordResetToken[]
  gasUsageToday   Float          @default(0)
  lastGasReset    DateTime       @default(now())
}

/// Rotating refresh tokens — one active per device/session.
model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  family    String
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([family])
  @@index([expiresAt])
}

/// Time-limited tokens for password reset and email verification.
model PasswordResetToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      TokenType
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model Transaction {
  id            String        @id @default(cuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id])
  txHash        String
  chainId       Int
  from          String
  to            String
  value         String        // wei as string
  token         String?       // null = native, otherwise ERC-20 symbol
  tokenAddress  String?
  type          TxType
  status        TxStatus      @default(PENDING)
  blockNumber   BigInt?
  gasUsed       String?
  timestamp     DateTime?
  createdAt     DateTime      @default(now())

  @@index([userId])
  @@index([txHash])
  @@index([chainId, from])
  @@index([chainId, to])
}

model Card {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  provider        CardProvider
  externalId      String        @unique
  type            CardType
  status          CardStatus    @default(ACTIVE)
  last4           String?
  dailyLimit      BigInt        @default(50000000)
  createdAt       DateTime      @default(now())
}

model CardSession {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  sessionKeyAddr  String
  provider        CardProvider
  dailyLimit      BigInt
  perTxLimit      BigInt
  validUntil      DateTime
  active          Boolean       @default(true)
  txHash          String?
  createdAt       DateTime      @default(now())
}

model Stream {
  id                String        @id @default(cuid())
  onChainStreamId   Int?
  senderId          String
  sender            User          @relation("sender", fields: [senderId], references: [id])
  recipientAddr     String
  token             String
  totalAmount       BigInt
  withdrawn         BigInt        @default(0)
  startTime         DateTime
  endTime           DateTime
  status            StreamStatus  @default(ACTIVE)
  txHash            String?
  createdAt         DateTime      @default(now())
}

model WebhookEvent {
  id              String        @id @default(cuid())
  provider        String
  eventType       String
  payload         Json
  processed       Boolean       @default(false)
  createdAt       DateTime      @default(now())
}

enum TokenType {
  PASSWORD_RESET
  EMAIL_VERIFICATION
}

enum KycStatus {
  NONE
  PENDING
  APPROVED
  REJECTED
}

enum CardProvider {
  IMMERSVE
  REAP
}

enum CardType {
  VIRTUAL
  PHYSICAL
}

enum CardStatus {
  ACTIVE
  FROZEN
  CANCELLED
  EXPIRED
}

enum StreamStatus {
  ACTIVE
  PAUSED
  CANCELLED
  COMPLETED
}

enum TxType {
  SEND
  RECEIVE
  SWAP
  BRIDGE
  CONTRACT_CALL
  USER_OP
}

enum TxStatus {
  PENDING
  CONFIRMED
  FAILED
  DROPPED
}
