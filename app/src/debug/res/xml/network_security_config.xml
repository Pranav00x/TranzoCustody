<network-security-config>
    <!-- Debug builds only: allow HTTP to LAN IPs (e.g. http://192.168.x.x:3000/) for local backend. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
